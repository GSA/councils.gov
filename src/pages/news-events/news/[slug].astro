---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import newsItems from '../../../data/news.json';

export async function getStaticPaths() {
  const items = (newsItems as any[]).filter((item) => item.kind === 'news');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const wavesUrl = `${baseUrl}assets/img/backgrounds/waves_2.svg`;

const formatDate = (dateString: string) => {
  const parsed = new Date(dateString);
  if (Number.isNaN(parsed.getTime())) return dateString;
  return parsed.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });
};

const body = Array.isArray(item.body) ? item.body : [];

/** Other news & events from the dataset (excludes current item). */
const relatedItems = (newsItems as any[]).filter(
  (i) => i.slug && i.slug !== item.slug && (i.kind === 'news' || i.kind === 'event')
);
---

<BaseLayout title={`${item.title} - News & Events - Councils.gov`} currentPage="news-events">
  <main id="main-content">
    <nav class="council-breadcrumb" aria-label="Breadcrumb">
      <ol class="usa-breadcrumb__list">
        <li class="usa-breadcrumb__list-item">
          <a href={baseUrl} class="usa-breadcrumb__link">
            <span>Home</span>
          </a>
        </li>
        <li class="usa-breadcrumb__list-item">
          <a href={`${baseUrl}news-events/`} class="usa-breadcrumb__link">
            <span>News & Events</span>
          </a>
        </li>
        <li class="usa-breadcrumb__list-item">
          <span class="usa-breadcrumb__current" aria-current="page">{item.title}</span>
        </li>
      </ol>
    </nav>
    <section
      class="usa-hero resources-hero"
      aria-label="News"
      style={`--hero-waves-url: url(${wavesUrl})`}
    >
      <div class="grid-container">
        <h1>{item.title}</h1>
      </div>
    </section>
    <article class="grid-container padding-top-4 usa-section">
      <div class="grid-row grid-gap">
        <div class={relatedItems.length > 0 ? 'tablet:grid-col-9' : 'tablet:grid-col-12'}>
      <div class="maxw-72 margin-bottom-4">
        <p>
          <time datetime={item.date}>{formatDate(item.date)}</time>
          {item.author && (
            <span class="display-block">By {item.author}</span>
          )}
        </p>
        {body.map((paragraph: string) => (
          <p>{paragraph}</p>
        ))}
      </div>
      {(item.tags?.length > 0 || item.councilAcronym) && (
        <ul class="usa-list usa-list--unstyled margin-top-4 content-tags" aria-label="Topics">
          {item.councilAcronym && (
            <li class="usa-tag margin-bottom-1">{item.councilAcronym}</li>
          )}
          {item.tags?.map((tag: string) => (
            <li class="usa-tag margin-bottom-1">{tag}</li>
          ))}
        </ul>
      )}
        </div>
        {relatedItems.length > 0 && (
        <aside class="tablet:grid-col-3 related-links-sidebar" aria-label="Related News & Events">
          <h2 class="font-sans-lg margin-top-0 margin-bottom-2">Related News & Events</h2>
          <ul class="usa-collection usa-collection--condensed">
            {relatedItems.map((related: any) => {
              const segment = related.kind === 'event' ? 'events' : 'news';
              const href = `${baseUrl}news-events/${segment}/${related.slug}/`;
              const dateStr = related.dateDisplay || (related.date ? new Date(related.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : '');
              const hasMeta = dateStr || related.author;
              return (
                <li class="usa-collection__item">
                  <div class="usa-collection__body">
                    <h4 class="usa-collection__heading">
                      <a class="usa-link" href={href}>{related.title}</a>
                    </h4>
                    {hasMeta && (
                      <ul class="usa-collection__meta" aria-label="More information">
                        {related.author && (
                          <li class="usa-collection__meta-item">By {related.author}</li>
                        )}
                        {dateStr && (
                          <li class="usa-collection__meta-item">
                            {related.date ? (
                              <time datetime={related.date}>{dateStr}</time>
                            ) : (
                              dateStr
                            )}
                          </li>
                        )}
                      </ul>
                    )}
                  </div>
                </li>
              );
            })}
          </ul>
        </aside>
        )}
      </div>
    </article>
  </main>
</BaseLayout>
