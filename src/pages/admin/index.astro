---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Councils.gov CMS</title>
    <style>
      img[alt="Logo"] {
        margin-left: 75px;
        width: 150px;
      }
      button {
        margin-top: 0 !important;
      }
    </style>
  </head>
  <body id="top-of-page">
    <script is:inline src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
    <script is:inline>
      const registerIdHook = () => {
        if (!window.CMS || typeof window.CMS.registerEventListener !== "function") {
          return;
        }

        const ensureListItemIds = (items, fallbackPrefix) => {
          if (!items || typeof items.map !== "function") {
            return items;
          }

          const baseTimestamp = Date.now();
          let sequence = 0;

          return items.map((item) => {
            const existingId = item.get("id");
            if (existingId && String(existingId).trim() !== "") {
              return item;
            }

            const councilValue = item.get("councilAcronym");
            const firstCouncil =
              councilValue && typeof councilValue.first === "function"
                ? councilValue.first()
                : councilValue;
            const prefix = String(firstCouncil || fallbackPrefix).trim() || fallbackPrefix;
            sequence += 1;
            const timestamp = `${baseTimestamp}${String(sequence).padStart(3, "0")}`;
            return item.set("id", `${prefix}-${timestamp}`);
          });
        };

        const slugify = (value) =>
          String(value || "")
            .toLowerCase()
            .trim()
            .replace(/[^a-z0-9\s-]/g, "")
            .replace(/\s+/g, "-")
            .replace(/-+/g, "-")
            .replace(/^-|-$/g, "");

        window.CMS.registerEventListener({
        name: "preSave",
        handler: ({ entry }) => {
          const data = entry.get("data");
          const collectionName = entry.get("collection");

          if (collectionName === "resources") {
            const resources = data.get("resources");
            const updatedResources = ensureListItemIds(resources, "RESOURCE");
            return entry.set("data", data.set("resources", updatedResources));
          }

          if (collectionName === "news_events") {
            const news = data.get("news");
            const updatedNews = ensureListItemIds(news, "NEWS").map((item) => {
              const title = item.get("title");
              const generatedSlug = slugify(title);
              return generatedSlug ? item.set("slug", generatedSlug) : item;
            });
            return entry.set("data", data.set("news", updatedNews));
          }

          return entry;
        },
      });
      };

      if (window.CMS && typeof window.CMS.registerEventListener === "function") {
        registerIdHook();
      } else {
        window.addEventListener("load", registerIdHook, { once: true });
      }
    </script>
  </body>
</html>
