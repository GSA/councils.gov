  const entries = Object.entries(agencyMap).sort((a, b) => b[0].length - a[0].length);
  for (const [key, filename] of entries) {
    const isAcronym = key.length <= 4;
    const matches = isAcronym
      ? new RegExp(`\\b${key}\\b`, 'i').test(text)
      : text.includes(key);
    if (matches) {
      return `/assets/img/members/${filename}`;
    }
  }

  return null;
