---
import { getImage } from 'astro:assets';
import CouncilLayout from '../../layouts/CouncilLayout.astro';
import matter from 'gray-matter';
import { readFileSync } from 'fs';
import { join } from 'path';
import { toArray } from '../../components/filters';

// Get all council members-leaders pages
export async function getStaticPaths() {
  const contentDir = join(process.cwd(), 'src/content/councils');
  const fs = await import('fs');
  const councils = fs.readdirSync(contentDir);
  
  return councils.map((councilSlug) => {
    const filePath = join(contentDir, councilSlug, 'members-leaders.md');
    if (!fs.existsSync(filePath)) return null;
    
    const fileContents = fs.readFileSync(filePath, 'utf-8');
    const { data: frontmatter } = matter(fileContents);
    
    // Get logo info from about.md
    const aboutPath = join(contentDir, councilSlug, 'about.md');
    let logoPath, logoAlt, logoClass, logoAspect;
    if (fs.existsSync(aboutPath)) {
      const aboutContents = fs.readFileSync(aboutPath, 'utf-8');
      const { data: aboutFrontmatter } = matter(aboutContents);
      logoPath = aboutFrontmatter.logoPath;
      logoAlt = aboutFrontmatter.logoAlt;
      logoClass = aboutFrontmatter.logoClass;
      logoAspect = aboutFrontmatter.logoAspect;
    }
    
    const members = frontmatter.members ?? [];
    const leaders = frontmatter.leaders ?? [];
    const coChairs = frontmatter.coChairs ?? [];
    const hasMembersLeaders = [].concat(members, leaders, coChairs).length > 0;

    // Check if this council has any news/events for the side nav
    const councilAcronym = (logoAlt as string)?.replace(/\s*Logo\s*$/i, '').trim() || (frontmatter.councilSlug as string)?.toUpperCase() || '';
    const newsPath = join(process.cwd(), 'src/data/news.json');
    let hasNewsEvents = false;
    if (fs.existsSync(newsPath)) {
      const newsData = JSON.parse(fs.readFileSync(newsPath, 'utf-8'));
      const newsItems = Array.isArray(newsData) ? newsData : (newsData.items ?? newsData.data ?? []);
      hasNewsEvents = newsItems.some((item: { councilAcronym?: string | string[] }) =>
        toArray(item.councilAcronym).includes(councilAcronym)
      );
    }

    // Check if this council has any resources for the side nav
    const resourcesPath = join(process.cwd(), 'src/data/resources.json');
    let hasResources = false;
    if (fs.existsSync(resourcesPath)) {
      const resourcesData = JSON.parse(fs.readFileSync(resourcesPath, 'utf-8'));
      const resourcesList = resourcesData.resources ?? resourcesData.items ?? (Array.isArray(resourcesData) ? resourcesData : []);
      hasResources = resourcesList.some((item: { councilAcronym?: string | string[] }) =>
        toArray(item.councilAcronym).includes(councilAcronym)
      );
    }

    // ICSP one-off: always show News & Events (links to statspolicy.gov) and Resources (internal page)
    if (councilSlug === 'icsp') {
      hasNewsEvents = true;
      hasResources = true;
    }

    return {
      params: { council: councilSlug },
      props: {
        frontmatter,
        logoPath,
        logoAlt,
        logoClass,
        logoAspect,
        hasMembersLeaders,
        hasNewsEvents,
        hasResources,
      },
    };
  }).filter(Boolean);
}

const { frontmatter, logoPath, logoAlt, logoClass, logoAspect, hasMembersLeaders, hasNewsEvents, hasResources } = Astro.props;
const councilAcronym = (logoAlt as string)?.replace(/\s*Logo\s*$/i, '').trim() || (frontmatter.councilSlug as string)?.toUpperCase() || '';
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path?: string) => (path && path.startsWith('/') ? `${baseUrl}${path.slice(1)}` : path);

const getLastName = (name: string) => {
  const withoutParens = name.replace(/\s*\([^)]*\)\s*$/, '').trim();
  const parts = withoutParens.split(/\s+/);
  return parts.length > 1 ? parts[parts.length - 1] : withoutParens;
};
/** Sort key: last name if person has name, otherwise full agency name for alphabetical sort. */
const getMemberSortKey = (item: { name?: string; agency?: string; department?: string }) => {
  if (item.name?.trim()) return getLastName(item.name);
  return (item.agency ?? item.department ?? '').trim();
};
const sortMembersAlphabetically = (
  a: { name?: string; agency?: string; department?: string },
  b: { name?: string; agency?: string; department?: string }
) => getMemberSortKey(a).localeCompare(getMemberSortKey(b), 'en-US', { sensitivity: 'base' });

const useCustomOrderForLeaders = frontmatter.useCustomOrderForLeaders === true;
const useCustomOrderForMembers = frontmatter.useCustomOrderForMembers === true;

const leadersList = frontmatter.leaders ?? [];
const membersList = frontmatter.members ?? [];

/** When custom order is on: use order field (1,2,3) if set; otherwise use list order. */
const applyCustomOrder = <T extends { order?: number }>(items: T[]) => {
  const hasExplicitOrder = items.some((item) => item.order != null && item.order > 0);
  if (!hasExplicitOrder) return [...items]; // use list order as-is (no sort)
  return [...items].sort((a, b) => {
    const oa = a.order ?? 9999;
    const ob = b.order ?? 9999;
    return oa - ob;
  });
};

const sortedLeaders =
  useCustomOrderForLeaders
    ? applyCustomOrder(leadersList)
    : [...leadersList].sort(sortMembersAlphabetically);
const sortedCoChairs = [...(frontmatter.coChairs ?? [])].sort(sortMembersAlphabetically);
const sortedMembers =
  useCustomOrderForMembers
    ? applyCustomOrder(membersList)
    : [...membersList].sort(sortMembersAlphabetically);

// Build optimized image map for leaders and members (WebP)
const leaderGlob = import.meta.glob<{ default: import('astro').ImageMetadata }>('../../assets/img/leaders/*.{png,jpg,jpeg,webp,svg}');
const memberGlob = import.meta.glob<{ default: import('astro').ImageMetadata }>('../../assets/img/members/*.{png,jpg,jpeg,gif,webp,svg}');
const optimizedImageMap = new Map<string, { src: string; width: number; height: number }>();

async function getOptimizedImage(path: string): Promise<{ src: string; width: number; height: number } | null> {
  const cached = optimizedImageMap.get(path);
  if (cached) return cached;
  const filename = path.split('/').pop() || '';
  const isLeader = path.includes('/leaders/');
  const glob = isLeader ? leaderGlob : memberGlob;
  const globKey = Object.keys(glob).find((k) => k.endsWith(filename));
  if (!globKey) return null;
  const mod = await glob[globKey]();
  const optimized = await getImage({ src: mod.default, width: 200, height: 200 });
  const src = baseUrl && baseUrl !== '/' && !optimized.src.startsWith(baseUrl.replace(/\/$/, ''))
    ? `${baseUrl.replace(/\/$/, '')}${optimized.src}`
    : optimized.src;
  const result = { src, width: 200, height: 200 };
  optimizedImageMap.set(path, result);
  return result;
}

const allImagePaths = new Set<string>();
[...sortedLeaders, ...sortedCoChairs].forEach((l: any) => l.image && allImagePaths.add(l.image));
sortedMembers.forEach((m: any) => {
  const img = getMemberImage(m);
  if (img) allImagePaths.add(img);
});
const optimizedImages = await Promise.all(
  Array.from(allImagePaths).map(async (path) => {
    const opt = await getOptimizedImage(path);
    return [path, opt] as const;
  })
);
const optimizedMap = new Map(optimizedImages.filter(([, o]) => o !== null) as [string, { src: string; width: number; height: number }][]);

function getImageSrc(path: string): { src: string; width: number; height: number } {
  const opt = optimizedMap.get(path);
  return opt ?? { src: withBase(path) ?? path, width: 200, height: 200 };
}

