---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResourceFilter from '../components/ResourceFilter';
import Papa from 'papaparse';
import { readFileSync } from 'fs';
import { join } from 'path';

const baseUrl = import.meta.env.BASE_URL;
const wavesUrl = `${baseUrl}assets/img/backgrounds/waves_2.svg`;

// Helper function to parse CSV and convert to resources format
function parseCSVToResources(csvPath: string): any[] {
  try {
    const csvContent = readFileSync(csvPath, 'utf-8');
    const parseResult = Papa.parse(csvContent, {
      header: true,
      skipEmptyLines: true,
      transformHeader: (header: string) => {
        // Remove quotes from header names if present
        return header.trim().replace(/^["']|["']$/g, '');
      },
    });

    return parseResult.data
      .filter((row: any) => row && Object.keys(row).length > 0) // Filter out completely empty rows
      .map((row: any, index: number) => {
        // Map CSV columns to expected resource structure - try multiple possible column name variations
        const resourceName = String(
          row['Resource name'] || 
          row['resource name'] || 
          row['Resource Name'] || 
          ''
        ).trim();
        const council = String(
          row['Council'] || 
          row['council'] || 
          ''
        ).trim();
        const focusArea = String(
          row['Focus Area'] || 
          row['focus area'] || 
          row['Focus area'] || 
          ''
        ).trim();
        const type = String(
          row['Type'] || 
          row['type'] || 
          ''
        ).trim();
        const year = String(
          row['Year'] || 
          row['year'] || 
          ''
        ).trim().replace(/[^0-9]/g, ''); // Remove any non-numeric characters
        const docLink = String(
          row['Document name or external link'] || 
          row['document name or external link'] || 
          ''
        ).trim();
        const websiteLink = String(
          row['If the document is already posted on an existing council website, provide the link here:'] || 
          row['if the document is already posted on an existing council website, provide the link here:'] || 
          ''
        ).trim();
        
        // Use website link if available, otherwise use document link
        const link = websiteLink || docLink;
        
        // Convert year to date format (YYYY-MM-DD, defaulting to January 1st)
        let date = '';
        if (year && year !== 'Unknown' && year !== '') {
          date = `${year}-01-01`;
        } else {
          date = '1900-01-01'; // Default for unknown dates
        }

        // Only return if we have at least a title and council
        if (!resourceName || !council) {
          return null;
        }

        return {
          id: `${council}-${index + 1}`,
          title: resourceName,
          description: '', // CSV doesn't have description, leaving empty
          type: type,
          focusArea: focusArea,
          councilAcronym: council,
          date: date,
          link: link,
        };
      })
      .filter((item: any) => item !== null); // Remove null entries
  } catch (error) {
    console.error(`Error parsing CSV file ${csvPath}:`, error);
    return [];
  }
}

// Read and parse both CSV files
const ciocPath = join(process.cwd(), 'src/data/CIOC_Resources.csv');
const coffaPath = join(process.cwd(), 'src/data/COFFA_resources.csv');

const ciocResources = parseCSVToResources(ciocPath);
const coffaResources = parseCSVToResources(coffaPath);

// Combine resources from both files
const resources = [...ciocResources, ...coffaResources];

// Ensure resources is always an array (fallback to empty array if parsing fails)
if (!Array.isArray(resources) || resources.length === 0) {
  console.warn('No resources loaded from CSV files');
}
---

<BaseLayout title="Resources - Councils.gov" currentPage="resources">

  <main id="main-content">
    <section class="usa-hero resources-hero" aria-label="Resources" style={`--hero-waves-url: url(${wavesUrl})`}>
      <div class="grid-container">
        <h1>Resources</h1>
        <p class="usa-intro font-md margin-top-2 margin-bottom-2">
        Access valuable resources, tools, and documentation to support your initiatives 
        and improve agency practices across all councils.
      </p>
      </div>
    </section>
    <section class="grid-container usa-section">
      <ResourceFilter client:load resources={resources} />
    </section>
  </main>
</BaseLayout>
