---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResourceFilter from '../components/ResourceFilter';
import ReturnToTop from '../components/ReturnToTop.astro';
import resourcesData from '../data/resources.json';

const baseUrl = import.meta.env.BASE_URL;
const wavesUrl = `${baseUrl}assets/img/backgrounds/waves_2.svg`;

const unsortedResources = Array.isArray(resourcesData)
  ? resourcesData
  : Array.isArray(resourcesData?.resources)
    ? resourcesData.resources
    : [];

const getResourceDateTimestamp = (resource) => {
  if (typeof resource?.date !== 'string' || resource.date.trim() === '') {
    return null;
  }

  const timestamp = Date.parse(resource.date);
  return Number.isNaN(timestamp) ? null : timestamp;
};

const resources = [...unsortedResources].sort((a, b) => {
  const aTimestamp = getResourceDateTimestamp(a);
  const bTimestamp = getResourceDateTimestamp(b);

  if (aTimestamp === null && bTimestamp === null) return 0;
  if (aTimestamp === null) return 1;
  if (bTimestamp === null) return -1;

  return bTimestamp - aTimestamp;
});

// Ensure resources is always an array (fallback to empty array if parsing fails)
if (!Array.isArray(resources) || resources.length === 0) {
  console.warn('No resources loaded from CSV files');
}
---

<BaseLayout title="Resources - Councils.gov" currentPage="resources">

  <main id="main-content" class="filter-page-main">
    <section class="usa-hero resources-hero" aria-label="Resources" style={`--hero-waves-url: url(${wavesUrl})`}>
      <div class="grid-container">
        <h1>Resources</h1>
        <p class="usa-intro font-md margin-top-2 margin-bottom-1">
        Access valuable resources, tools, and documentation to support your initiatives 
        and improve agency practices across all councils.
      </p>
      </div>
    </section>
    <section class="grid-container usa-section">
      <ResourceFilter client:load resources={resources} baseUrl={baseUrl} />
    </section>
    <ReturnToTop />
  </main>
</BaseLayout>
