---
import BaseLayout from '../layouts/BaseLayout.astro';
import matter from 'gray-matter';
import { readFileSync } from 'fs';
import { join } from 'path';
const baseUrl = import.meta.env.BASE_URL;
const wavesUrl = `${baseUrl}assets/img/backgrounds/waves_2.svg`;

const homeContentPath = join(process.cwd(), 'src/content/pages/home.md');
const { data: homeData } = matter(readFileSync(homeContentPath, 'utf-8'));
const {
  title = 'Councils.gov - Home',
  heroText = '',
  councilsHeading = 'Federal Executive Councils',
  councils = [],
} = homeData as {
  title?: string;
  heroText?: string;
  councilsHeading?: string;
  councils?: Array<{
    title: string;
    acronym?: string;
    href: string;
    logo: string;
    logoAlt?: string;
    logoClass?: string;
    description: string;
  }>;
};
const councilsList = Array.isArray(councils) ? councils : [];
const withBase = (path: string) => (path.startsWith('/') ? `${baseUrl}${path.slice(1)}` : path);
---

<BaseLayout title={title} currentPage="home">

  <main id="main-content">
    <section class="usa-hero" aria-label="Introduction" style={`--hero-waves-url: url(${wavesUrl})`}>
      <div class="grid-container">
        <div class="usa-hero__callout">
          <h1 class="usa-sr-only">Federal Executive Councils</h1>
          <p class="usa-hero__text padding-y-2">
            {heroText}
          </p>
        </div>
      </div>
    </section>

    <section class="usa-section councils-section" style={`--councils-waves-url: url(${wavesUrl})`}>
      <div class="grid-container">
        <h2>{councilsHeading}</h2>
        <div class="councils-grid margin-bottom-2">
        {councilsList.map((council) => (
          <a href={withBase(council.href)} class="usa-card display-block text-no-underline">
            <div class="usa-card__container">
              <div class="usa-card__media">
                <div class="usa-card__img">
                  <img
                    src={withBase(council.logo)}
                    alt={council.logoAlt || ''}
                    class={council.logoClass || 'council-logo'}
                  />
                </div>
              </div>
              <header class="usa-card__header text-center padding-top-0">
                <h3 class="usa-card__heading">{council.title}</h3>
              </header>
              {/* <div class="usa-card__body">
                <p>{council.description}</p>
              </div> */}
              <div class="usa-card__footer text-center margin-top-2 margin-bottom-1">
                <span class="usa-button">About {council.acronym}</span>
              </div>
            </div>
          </a>
        ))}
        </div>
      </div>
      <div class="grid-container footer-grid-container usa-footer__return-to-top">
        <a href="#">Return to top</a>
      </div>
    </section>
  </main>
</BaseLayout>



