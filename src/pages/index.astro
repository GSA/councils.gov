---
import BaseLayout from '../layouts/BaseLayout.astro';
import matter from 'gray-matter';
import { readFileSync } from 'fs';
import { join } from 'path';
const baseUrl = import.meta.env.BASE_URL;
const wavesUrl = `${baseUrl}assets/img/backgrounds/waves_2.svg`;
const heroImageUrl = `${baseUrl}assets/img/white_house_hero.webp`;

const homeContentPath = join(process.cwd(), 'src/content/pages/home.md');
const { data: homeData } = matter(readFileSync(homeContentPath, 'utf-8'));
const {
  title = 'Councils.gov - Home',
  heroText = '',
  councils = [],
} = homeData as {
  title?: string;
  heroText?: string;
  councilsHeading?: string;
  councils?: Array<{
    title: string;
    acronym?: string;
    href: string;
    logo: string;
    logoAlt?: string;
    logoClass?: string;
    description: string;
  }>;
};
const councilsList = Array.isArray(councils) ? councils : [];
const withBase = (path: string) => (path.startsWith('/') ? `${baseUrl}${path.slice(1)}` : path);
---

<BaseLayout title={title} currentPage="home">

  <main id="main-content" class="home-page">
    <section class="usa-hero" aria-label="Introduction" style={`--hero-bg-url: url(${heroImageUrl})`}>
      <div class="grid-container">
        <div class="usa-hero__callout">
          <h1 class="usa-hero__heading">Welcome to the new Councils.gov!</h1>
          {heroText && <p>{heroText}</p>}
        </div>
      </div>
    </section>

    <section class="usa-section councils-section" style={`--councils-waves-url: url(${wavesUrl})`}>
      <div class="grid-container">
        <div class="grid-row grid-gap padding-bottom-2">
          <div class="tablet:grid-col-10 tablet:grid-offset-1 text-center">
            <p class="font-serif font-serif-24 margin-top-0">The Federal Executive Councils are comprised of senior level representatives from departments and agencies that span the breadth of the federal government. By leveraging the collective expertise of their members, the councils strengthen core functional areas within the government and implement Administration priorities.</p>
          </div>
        </div>
        <hr>
        <div class="councils-grid padding-y-4">
        {councilsList.map((council) => (
          <a href={withBase(council.href)} class="usa-card display-block text-no-underline margin-0">
            <div class="usa-card__container">
              <div class="usa-card__media">
                <div class="usa-card__img">
                  <img
                    src={withBase(council.logo)}
                    alt={council.logoAlt || ''}
                    class={council.logoClass || 'council-logo'}
                  />
                </div>
              </div>
              <header class="usa-card__header text-center padding-top-1">
                <h3 class="usa-card__heading">
                  {council.acronym ? `${council.title} (${council.acronym})` : council.title}
                </h3>
              </header>
              {/* <div class="usa-card__body">
                <p>{council.description}</p>
              </div> */}
              <div class="usa-card__footer text-center margin-top-2 margin-bottom-1">
                <span class="usa-button">About {council.acronym}</span>
              </div>
            </div>
          </a>
        ))}
        </div>
      </div>
      <div class="grid-container footer-grid-container usa-footer__return-to-top">
        <a href="#">Return to top</a>
      </div>
    </section>
  </main>
</BaseLayout>



