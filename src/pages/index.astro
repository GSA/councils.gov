---
import { getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ReturnToTop from '../components/ReturnToTop.astro';
import { getCouncilsForHome } from '../data/councilsData';
import matter from 'gray-matter';
import { readFileSync } from 'fs';
import { join } from 'path';

import heroImage from '../assets/img/white_house_hero.webp';
const optimizedHero = await getImage({ src: heroImage, width: 1920 });

const baseUrl = import.meta.env.BASE_URL;
const wavesUrl = `${baseUrl}assets/img/backgrounds/waves_2.svg`;

const homeContentPath = join(process.cwd(), 'src/content/pages/home.md');
const { data: homeData } = matter(readFileSync(homeContentPath, 'utf-8'));
const {
  title = 'Councils.gov - Home',
  heroHeading = 'Welcome to the new Councils.gov!',
  heroText = '',
  introText = '',
} = homeData as { title?: string; heroHeading?: string; heroText?: string; introText?: string; councilsHeading?: string };

const councilsList = getCouncilsForHome();
const withBase = (path: string | null | undefined) => {
  if (path == null) return '';
  return path.startsWith('/') ? `${baseUrl}${path.slice(1)}` : path;
};
---

<BaseLayout title={title} currentPage="home">
  <Fragment slot="head">
    <link rel="preload" as="image" href={optimizedHero.src} fetchpriority="high" />
  </Fragment>
  <main id="main-content" class="home-page">
    <section class="usa-hero usa-hero--hero-img" aria-label="Introduction">
      <img
        src={optimizedHero.src}
        alt=""
        width={heroImage.width}
        height={heroImage.height}
        fetchpriority="high"
        loading="eager"
        decoding="async"
        class="usa-hero__bg-img"
      />
      <div class="grid-container">
        <div class="usa-hero__callout">
          <h1 class="usa-hero__heading">{heroHeading}</h1>
          {heroText && <p>{heroText}</p>}
        </div>
      </div>
    </section>

    <section class="usa-section councils-section" style={`--councils-waves-url: url(${wavesUrl})`}>
      <div class="grid-container">
        <div class="grid-row grid-gap padding-bottom-2">
          <div class="tablet:grid-col-10 tablet:grid-offset-1 text-center">
            {introText && <p class="font-serif-sm tablet:font-serif-24 margin-top-0">{introText}</p>}
          </div>
        </div>
        <hr>
        <div class="councils-grid padding-y-4">
        {councilsList.map((council) => (
          <a
            href={withBase(council.href)}
            class="usa-card display-block text-no-underline margin-0"
            aria-label={council.acronym ? `About ${council.title} (${council.acronym})` : `About ${council.title}`}
          >
            <div class="usa-card__container">
              <div class="usa-card__media">
                {council.logo ? (
                  <div class="usa-card__img">
                    <img
                      src={withBase(council.logo)}
                      alt={council.logoAlt || ''}
                      class={council.logoClass || 'council-logo'}
                    />
                  </div>
                ) : (
                  <div class="usa-card__img usa-card__img--placeholder" aria-hidden="true" />
                )}
              </div>
              <header class="usa-card__header text-center padding-top-1">
                <h2 class="usa-card__heading">
                  {council.acronym ? `${council.title} (${council.acronym})` : council.title}
                </h2>
              </header>
              {/* <div class="usa-card__body">
                <p>{council.description}</p>
              </div> */}
              <div class="usa-card__footer text-center margin-top-2 margin-bottom-1">
                <span class="usa-button">About {council.acronym}</span>
              </div>
            </div>
          </a>
        ))}
        </div>
      </div>
      <ReturnToTop />
    </section>
  </main>
</BaseLayout>

