---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsFilter, { type NewsItem } from '../components/NewsFilter';
import ReturnToTop from '../components/ReturnToTop.astro';
import newsData from '../data/news.json';

const baseUrl = import.meta.env.BASE_URL;
const wavesUrl = `${baseUrl}assets/img/backgrounds/waves_2.svg`;
const newsItems = Array.isArray(newsData)
  ? (newsData as NewsItem[])
  : ((newsData.news ?? newsData.items ?? newsData.data ?? []) as NewsItem[]);
---

<BaseLayout title="News & Events - Councils.gov" currentPage="news-events">
  <main id="main-content" class="filter-page-main">
    <section
      class="usa-hero resources-hero"
      aria-label="News and Events"
      style={`--hero-waves-url: url(${wavesUrl})`}
    >
      <div class="grid-container">
        <h1>News & Events</h1>
        <p class="usa-intro font-md margin-top-2 margin-bottom-1">
          Browse updates and announcements from the Federal Executive Councils.
        </p>
      </div>
    </section>
    <section class="grid-container usa-section">
      <NewsFilter client:load items={newsItems} baseUrl={baseUrl} />
    </section>
    <ReturnToTop />
  </main>
</BaseLayout>
