---
import CouncilLayout from '../../../layouts/CouncilLayout.astro';
import matter from 'gray-matter';
import { readFileSync } from 'fs';
import { join } from 'path';

// Get all council members-leaders pages
export async function getStaticPaths() {
  const contentDir = join(process.cwd(), 'src/content/councils');
  const fs = await import('fs');
  const councils = fs.readdirSync(contentDir);
  
  return councils.map((councilSlug) => {
    const filePath = join(contentDir, councilSlug, 'members-leaders.md');
    if (!fs.existsSync(filePath)) return null;
    
    const fileContents = fs.readFileSync(filePath, 'utf-8');
    const { data: frontmatter } = matter(fileContents);
    
    // Get logo info from about.md
    const aboutPath = join(contentDir, councilSlug, 'about.md');
    let logoPath, logoAlt, logoClass;
    if (fs.existsSync(aboutPath)) {
      const aboutContents = fs.readFileSync(aboutPath, 'utf-8');
      const { data: aboutFrontmatter } = matter(aboutContents);
      logoPath = aboutFrontmatter.logoPath;
      logoAlt = aboutFrontmatter.logoAlt;
      logoClass = aboutFrontmatter.logoClass;
    }
    
    const members = frontmatter.members ?? [];
    const leaders = frontmatter.leaders ?? [];
    const coChairs = frontmatter.coChairs ?? [];
    const hasMembersLeaders = [].concat(members, leaders, coChairs).length > 0;

    return {
      params: { council: councilSlug },
      props: {
        frontmatter,
        logoPath,
        logoAlt,
        logoClass,
        hasMembersLeaders,
      },
    };
  }).filter(Boolean);
}

const { frontmatter, logoPath, logoAlt, logoClass, hasMembersLeaders } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path?: string) => (path && path.startsWith('/') ? `${baseUrl}${path.slice(1)}` : path);

// Function to get member logo image path
function getMemberImage(member: any): string | null {
  // If image is explicitly set, use it
  if (member.image) {
    return member.image;
  }
  
  // Extract agency name from agency/description/name
  const text = (member.agency || member.description || member.name || '').toLowerCase();
  
  // Map agency names to image filenames
  const agencyMap: Record<string, string> = {
    'department of agriculture': 'Department of Agriculture.png',
    'department of commerce': 'Department of Commerce.png',
    'department of education': 'Department of Education.png',
    'department of energy': 'Department of Energy.png',
    'department of health and human services': 'Department of Health and Human Services.png',
    'hhs': 'Department of Health and Human Services.png',
    'department of homeland security': 'Department of Homeland Security.png',
    'department of housing and urban development': 'Department of Housing and Urban Development.png',
    'hud': 'Department of Housing and Urban Development.png',
    'department of justice': 'Department of Justice.png',
    'department of labor': 'Department of Labor.png',
    'department of state': 'Department of State.png',
    'department of the air force': 'Department of the Air Force.png',
    'department of the army': 'Department of the Army.png',
    'department of the interior': 'Department of the Interior.png',
    'department of the navy': 'Department of the Navy.png',
    'department of the treasury': 'Department of the Treasury.png',
    'department of transportation': 'Department of Transportation.png',
    'department of veterans affairs': 'Department of Veterans Affairs.png',
    'va': 'Department of Veterans Affairs.png',
    'department of war': 'Department of War.png',
    'environmental protection agency': 'Environmental Protection Agency.png',
    'epa': 'Environmental Protection Agency.png',
    'federal deposit insurance corporation': 'Federal Deposit Insurance Corporation.png',
    'fdic': 'Federal Deposit Insurance Corporation.png',
    'general services administration': 'General Services Administration.png',
    'gsa': 'General Services Administration.png',
    'national archives and records administration': 'National Archives and Records Administration.png',
    'national aeronautics and space administration': 'National Aeronautics and Space Administration.png',
    'nasa': 'National Aeronautics and Space Administration.png',
    'national science foundation': 'National Science Foundation.png',
    'nsf': 'National Science Foundation.png',
    'nuclear regulatory commission': 'Nuclear Regulatory Commission.png',
    'nrc': 'Nuclear Regulatory Commission.png',
    'office of the director of national intelligence': 'Office of the Director of National Intelligence.png',
    'odni': 'Office of the Director of National Intelligence.png',
    'office of personnel management': 'Office of Personnel Management.png',
    'opm': 'Office of Personnel Management.png',
    'small business administration': 'Small Business Administration.png',
    'sba': 'Small Business Administration.png',
    'social security administration': 'Social Security Administration.png',
    'ssa': 'Social Security Administration.png',
    'appraisal subcommittee': 'Appraisal Subcommittee of the Federal Financial Institutions Examination Council.png',
  };
  
  // Try to find a match (guard short acronyms with word boundaries)
  for (const [key, filename] of Object.entries(agencyMap)) {
    const isAcronym = key.length <= 4;
    const matches = isAcronym
      ? new RegExp(`\\b${key}\\b`, 'i').test(text)
      : text.includes(key);
    if (matches) {
      return `/assets/img/members/${filename}`;
    }
  }
  
  return null;
}
---

<CouncilLayout 
  title={`${frontmatter.title} - Councils.gov`} 
  currentPage="members-leaders" 
  councilName={frontmatter.councilName} 
  councilSlug={frontmatter.councilSlug}
  logoPath={logoPath}
  logoAlt={logoAlt}
  logoClass={logoClass}
  hasMembersLeaders={hasMembersLeaders}
>
  <h2>{frontmatter.title}</h2>
  
  <p class="usa-intro">
    {frontmatter.intro}
  </p>

  {frontmatter.leaders && frontmatter.leaders.length > 0 && (
    <>
      <h2 class="margin-top-4">Leadership</h2>
      <div class="grid-row grid-gap margin-top-2 leadership-grid">
        {frontmatter.leaders.map((leader: any) => {
          const description =
            leader.description ?? leader.title ?? leader.bio ?? leader.role ?? leader.agency ?? '';
          return (
          <div class="tablet:grid-col-6">
            <div class="usa-card">
              <div class="usa-card__container">
                {leader.image && (
                  <div class="usa-card__media">
                    <div class="usa-card__img">
                      <img src={withBase(leader.image)} alt={leader.name} />
                    </div>
                  </div>
                )}
                <div class="usa-card__body">
                  <h3 class="margin-top-0">{leader.name}</h3>
                  {description && <p class="margin-top-0">{description}</p>}
                </div>
              </div>
            </div>
          </div>
          );
        })}
      </div>
    </>
  )}

  {frontmatter.coChairs && frontmatter.coChairs.length > 0 && (
    <>
      <h2 class="margin-top-4">Co-Chairs</h2>
      <div class="grid-row grid-gap margin-top-2 members-grid">
        {frontmatter.coChairs.map((leader: any) => {
          const description =
            leader.description ?? leader.title ?? leader.bio ?? leader.role ?? leader.agency ?? '';
          return (
          <div class="tablet:grid-col-6 desktop:grid-col-4">
            <div class="usa-card">
              <div class="usa-card__container">
                {leader.image && (
                  <div class="usa-card__media">
                    <div class="usa-card__img">
                      <img src={withBase(leader.image)} alt={leader.name} />
                    </div>
                  </div>
                )}
                <div class="usa-card__body">
                  <h3 class="margin-top-0">{leader.name}</h3>
                  {description && <p class="margin-top-0">{description}</p>}
                </div>
              </div>
            </div>
          </div>
          );
        })}
      </div>
    </>
  )}

  <h2 class="margin-top-4">Members</h2>
  
  {frontmatter.members && frontmatter.members.length > 0 && (
    <div class="members-grid margin-top-2">
      {frontmatter.members.map((member: any) => {
        const department = member.agency ?? member.department ?? member.description ?? member.title ?? '';
        const memberImage = getMemberImage(member);
        return (
        <div class="usa-card">
          <div class="usa-card__container">
            {memberImage && (
              <div class="usa-card__media">
                <div class="usa-card__img">
                  <img src={withBase(memberImage)} alt={member.name} />
                </div>
              </div>
            )}
            <div class="usa-card__body">
              <h3 class="margin-top-0">{member.name}</h3>
              {department && <p class="margin-top-0">{department}</p>}
            </div>
          </div>
        </div>
        );
      })}
    </div>
  )}
</CouncilLayout>
