<script>
  (function() {
    'use strict';

    function syncCardAccordion(button, options) {
      const card = button.closest('.usa-card');
      if (!card) return;

      const isExpanded = button.getAttribute('aria-expanded') === 'true';
      const contentId = button.getAttribute('aria-controls');
      const content = contentId ? document.getElementById(contentId) : null;
      const gridItem = card.closest('[data-card-grid-item]');

      if (content) {
        content.hidden = !isExpanded;
      }

      if (gridItem) {
        gridItem.classList.toggle('desktop:grid-col-6', !isExpanded);
        gridItem.classList.toggle('usa-card-grid-item--expanded', isExpanded);
      }

      card.classList.toggle('usa-card--expanded', isExpanded);

      if (!button.dataset.cardAccordionLabel) {
        button.dataset.cardAccordionLabel = button.textContent.trim();
      }

      const heading = card.querySelector('.usa-card__heading');
      const headingText = heading ? heading.textContent.trim() : '';

      if (isExpanded) {
        const closeLabel = button.dataset.cardAccordionCloseLabel || 'Close details';
        button.setAttribute(
          'aria-label',
          headingText ? `${closeLabel}: ${headingText}` : closeLabel
        );
      } else {
        button.setAttribute(
          'aria-label',
          headingText
            ? `${button.dataset.cardAccordionLabel}: ${headingText}`
            : button.dataset.cardAccordionLabel
        );
      }
    }

    function toggleCardAccordion(button, options) {
      const willExpand = button.getAttribute('aria-expanded') !== 'true';
      const cardGroup = button.closest('.usa-card-group');

      if (willExpand && cardGroup) {
        cardGroup
          .querySelectorAll('[data-card-accordion-button][aria-expanded="true"]')
          .forEach(function(openButton) {
            if (openButton === button) return;
            openButton.setAttribute('aria-expanded', 'false');
            syncCardAccordion(openButton);
          });
      }

      button.setAttribute('aria-expanded', willExpand ? 'true' : 'false');
      syncCardAccordion(button, options);
    }

    function syncCardAccordions(root) {
      (root || document)
        .querySelectorAll('[data-card-accordion-button]')
        .forEach(syncCardAccordion);
    }

    function getCardAction(card) {
      return card.querySelector('[data-card-accordion-button], .usa-card__footer a[href]');
    }

    function shouldIgnoreCardClick(event, card) {
      if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
        return true;
      }

      if (card.classList.contains('usa-card--expanded')) {
        return true;
      }

      if (event.target.closest('a, button, input, select, textarea, label')) {
        return true;
      }

      if (window.getSelection && String(window.getSelection()).trim()) {
        return true;
      }

      return false;
    }

    document.addEventListener('click', function(event) {
      const button = event.target.closest('[data-card-accordion-button]');
      if (button) {
        event.preventDefault();
        event.stopPropagation();
        toggleCardAccordion(button);
        return;
      }

      const card = event.target.closest('.usa-card-group .usa-card--clickable');
      if (!card || shouldIgnoreCardClick(event, card)) return;

      const action = getCardAction(card);
      if (action) action.click();
    }, true);

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        syncCardAccordions(document);
      });
    } else {
      syncCardAccordions(document);
    }

    document.addEventListener('astro:after-swap', function() {
      window.setTimeout(function() {
        syncCardAccordions(document);
      }, 0);
    });
    document.addEventListener('astro:page-load', function() {
      window.setTimeout(function() {
        syncCardAccordions(document);
      }, 0);
    });
  })();
</script>
