---
import { footerCouncils } from "../data/footerCouncils";

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => (path.startsWith("/") ? `${baseUrl}${path.slice(1)}` : path);
---

<footer class="usa-footer" role="contentinfo">
  <div class="grid-container footer-grid-container usa-footer__return-to-top">
    <a href="#">Return to top</a>
  </div>
  <div class="usa-footer__primary-section">
    <div class="grid-container footer-grid-container">
      <nav class="usa-footer__nav" aria-label="Pre-footer links">
        <div class="footer-councils-grid">
          {footerCouncils.map((council) => (
            <a href={withBase(council.href)} class="footer-council-card">
              <div class="footer-council-card__content">
                <div class="footer-council-card__name">{council.name}</div>
                <div class="footer-council-card__logo">
                  <img
                    src={withBase(council.logo)}
                    alt=""
                    class="footer-council-card__logo-img"
                  />
                </div>
              </div>
            </a>
          ))}
        </div>
      </nav>
    </div>
  </div>
</footer>

