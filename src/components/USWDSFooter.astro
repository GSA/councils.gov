<style>
  .footer-councils-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  @media (min-width: 40rem) {
    .footer-councils-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .footer-council-card {
    display: block;
    background-color: white;
    border-bottom: 5px solid #8B0A03;
    padding: 1.5rem;
    text-decoration: none;
    color: #1b1b1b;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    height: 100%;
  }

  .footer-council-card:hover {
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
    transform: translateY(-2px);
    text-decoration: none;
    color: #1b1b1b;
  }

  .footer-council-card__content {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-council-card__logo {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-council-card__logo-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .footer-council-card__name {
    flex: 1;
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.4;
  }
</style>

