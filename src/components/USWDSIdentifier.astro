---
const baseUrl = import.meta.env.BASE_URL;
---

<div class="usa-identifier">
  <section
    class="usa-identifier__section usa-identifier__section--masthead"
    aria-label="Agency identifier"
  >
    <div class="usa-identifier__container">
      <div class="usa-identifier__logos">
        <a href={baseUrl} class="usa-identifier__logo">
          <img
            class="usa-identifier__logo-img"
            src={`${baseUrl}assets/img/logo-img.png`}
            alt="Councils.gov"
          />
          <img
            class="usa-identifier__logo-img usa-identifier__logo-img--mobile"
            src={`${baseUrl}assets/img/logo-img.png`}
            alt="Councils.gov"
          />
        </a>
      </div>
      <div class="usa-identifier__identity" aria-label="Agency description">
        <p class="usa-identifier__identity-domain">Councils.gov</p>
        <p class="usa-identifier__identity-disclaimer">
          An official website of the <a href="https://www.usa.gov/">United States government</a>
        </p>
      </div>
    </div>
  </section>
  <nav
    class="usa-identifier__section usa-identifier__section--required-links"
    aria-label="Important links"
  >
    <div class="usa-identifier__container">
      <ul class="usa-identifier__required-links-list">
        <li class="usa-identifier__required-links-item">
          <a href="https://www.usa.gov/about-us" class="usa-identifier__required-link usa-link">
            About USAGov
          </a>
        </li>
        <li class="usa-identifier__required-links-item">
          <a href="https://www.usa.gov/accessibility" class="usa-identifier__required-link usa-link">
            Accessibility support
          </a>
        </li>
        <li class="usa-identifier__required-links-item">
          <a href="https://www.usa.gov/foia" class="usa-identifier__required-link usa-link">
            FOIA requests
          </a>
        </li>
        <li class="usa-identifier__required-links-item">
          <a href="https://www.usa.gov/no-fear-act" class="usa-identifier__required-link usa-link">
            No FEAR Act data
          </a>
        </li>
        <li class="usa-identifier__required-links-item">
          <a href="https://www.usa.gov/office-of-inspector-general" class="usa-identifier__required-link usa-link">
            Office of the Inspector General
          </a>
        </li>
        <li class="usa-identifier__required-links-item">
          <a href="https://www.usa.gov/performance" class="usa-identifier__required-link usa-link">
            Performance reports
          </a>
        </li>
        <li class="usa-identifier__required-links-item">
          <a href="https://www.usa.gov/privacy-policy" class="usa-identifier__required-link usa-link">
            Privacy policy
          </a>
        </li>
      </ul>
    </div>
  </nav>
  <section
    class="usa-identifier__section usa-identifier__section--usagov"
    aria-label="U.S. government information and services"
  >
    <div class="usa-identifier__container">
      <div class="usa-identifier__usagov-description">
        Looking for U.S. government information and services?
      </div>
      <a href="https://www.usa.gov/" class="usa-link">Visit USA.gov</a>
    </div>
  </section>
</div>

