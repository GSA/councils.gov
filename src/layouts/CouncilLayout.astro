---
interface Props {
  title?: string;
  currentPage?: string;
  councilName: string;
  councilSlug: string;
  /** Council acronym for filter (e.g. CIOC). When set, Resources and News & Events links include ?council= for pre-filtering. */
  councilAcronym?: string;
  logoPath?: string;
  logoAlt?: string;
  logoClass?: string;
  /** 'square' for compact logos (ICSP, CIOC); omit for wide/landscape logos */
  logoAspect?: 'square';
  /** When false, the "Leadership & Members" side nav item is hidden. */
  hasMembersLeaders?: boolean;
  /** When false, the "News & Events" side nav item is hidden. */
  hasNewsEvents?: boolean;
  /** When false, the "Resources" side nav item is hidden. */
  hasResources?: boolean;
}

import BaseLayout from './BaseLayout.astro';
import ReturnToTop from '../components/ReturnToTop.astro';

const { title, currentPage = "about", councilName, councilSlug, councilAcronym, logoPath, logoAlt, logoClass, logoAspect, hasMembersLeaders = true, hasNewsEvents = true, hasResources = true } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const wavesUrl = `${baseUrl}assets/img/backgrounds/waves_2.svg`;
const withBase = (path?: string) => (path && path.startsWith('/') ? `${baseUrl}${path.slice(1)}` : path);

const councilQuery = councilAcronym ? `?council=${encodeURIComponent(councilAcronym)}` : '';
// ICSP one-off: News & Events links to statspolicy.gov; Resources uses internal page like other councils
const resourcesHref = `${baseUrl}resources/${councilQuery}`;
const newsEventsHref = councilSlug === 'icsp' ? 'https://statspolicy.gov/resources/' : `${baseUrl}news-events/${councilQuery}`;
const resourcesExternal = false;
const newsEventsExternal = councilSlug === 'icsp';
const allNavItems = [
  { href: `${baseUrl}${councilSlug}/`, label: "About", id: "about" },
  { href: `${baseUrl}${councilSlug}/members-leaders/`, label: "Leadership & Members", id: "members-leaders" },
  { href: newsEventsHref, label: "News & Events", id: "news-events", external: newsEventsExternal },
  { href: resourcesHref, label: "Resources", id: "resources", external: resourcesExternal },
];
let navItems = allNavItems;
if (!hasMembersLeaders) navItems = navItems.filter((item) => item.id !== "members-leaders");
if (!hasNewsEvents) navItems = navItems.filter((item) => item.id !== "news-events");
if (!hasResources) navItems = navItems.filter((item) => item.id !== "resources");
---

<BaseLayout title={title || `${councilName} - Councils.gov`} currentPage={currentPage}>

  <main id="main-content">
    <nav class="council-breadcrumb" aria-label="Breadcrumb">
      <ol class="usa-breadcrumb__list">
        <li class="usa-breadcrumb__list-item">
          <a href={baseUrl} class="usa-breadcrumb__link">
            <span>Home</span>
          </a>
        </li>
        <li class="usa-breadcrumb__list-item">
          <span class="usa-breadcrumb__current" aria-current="page">{councilName}</span>
        </li>
      </ol>
    </nav>
    <section class="council-hero usa-section padding-y-3" style={`--council-waves-url: url(${wavesUrl})`}>
      <div class="grid-container">
        <div class={`grid-row grid-gap sidebar-layout${!logoPath ? ' council-hero__row--no-logo' : ''}`}>
          {logoPath && (
            <div class="sidebar-layout__sidebar">
              <div class={`council-hero__logo-container${logoAspect === 'square' ? ' council-hero__logo-container--square' : ''}`}>
                <img src={withBase(logoPath)} alt={logoAlt || `${councilName} Logo`} class={logoClass || "council-hero__logo"} />
              </div>
            </div>
          )}
          <div class={`sidebar-layout__main flex-justify-center${!logoPath ? ' council-hero__main--no-logo' : ''}`}>
            <div class="council-hero__content">
              <p class="council-hero__brow">{councilName}</p>
              <h1 class="council-hero__title">
                {currentPage === "about" ? `About ${councilSlug.toUpperCase()}` : 
                 currentPage === "members-leaders" ? `Leadership & Members` : 
                 title || `${councilName}`}
              </h1>
            </div>
          </div>
        </div>
      </div>
    </section>
    <div class="usa-section">
      <div class="grid-container">
        <div class="grid-row grid-gap sidebar-layout">
          <aside class="sidebar-layout__sidebar">
            <nav aria-label="Side navigation" class="sticky-nav">
              <ul class="usa-sidenav">
                {navItems.map((item) => (
                  <li class="usa-sidenav__item">
                    <a
                      href={item.href}
                      class={[currentPage === item.id ? "usa-current" : "", item.external ? "usa-link usa-link--external" : ""].filter(Boolean).join(" ")}
                      {...(item.external && { target: "_blank", rel: "noreferrer noopener" })}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
          <div class="sidebar-layout__main">
            <slot />
          </div>
        </div>
      </div>
    </div>
    <ReturnToTop />
  </main>
</BaseLayout>


