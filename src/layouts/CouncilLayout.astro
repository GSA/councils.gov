---
interface Props {
  title?: string;
  currentPage?: string;
  councilName: string;
  councilSlug: string;
  logoPath?: string;
  logoAlt?: string;
  logoClass?: string;
}

import BaseLayout from './BaseLayout.astro';

const { title, currentPage = "about", councilName, councilSlug, logoPath, logoAlt, logoClass } = Astro.props;

const navItems = [
  { href: `/councils/${councilSlug}/about`, label: "About", id: "about" },
  { href: `/councils/${councilSlug}/members-leaders`, label: "Leadership and Members", id: "members-leaders" },
  { href: "/resources", label: "Resources", id: "resources" },
];
---

<BaseLayout title={title || `${councilName} - Councils.gov`} currentPage={currentPage}>

  <main id="main-content">
    <nav class="council-breadcrumb" aria-label="Breadcrumb">
      <ol class="usa-breadcrumb__list">
        <li class="usa-breadcrumb__list-item">
          <a href="/" class="usa-breadcrumb__link">
            <span>Home</span>
          </a>
        </li>
        <li class="usa-breadcrumb__list-item">
          <span class="usa-breadcrumb__current" aria-current="page">{councilName}</span>
        </li>
      </ol>
    </nav>
    {logoPath && (
      <section class="council-hero usa-section">
        <div class="grid-container">
          <div class="grid-row grid-gap">
            <div class="tablet:grid-col-3">
              <div class="council-hero__logo-container">
                <img src={logoPath} alt={logoAlt || `${councilName} Logo`} class={logoClass || "council-hero__logo"} />
              </div>
            </div>
            <div class="tablet:grid-col-9 flex-justify-center">
              <div class="council-hero__content">
                <p class="council-hero__brow">{councilName}</p>
                <h1 class="council-hero__title">
                  {currentPage === "about" ? `About ${councilSlug.toUpperCase()}` : 
                   currentPage === "members-leaders" ? `Leadership and Members` : 
                   title || `${councilName}`}
                </h1>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}
    <div class="usa-section">
      <div class="grid-container">
        <div class="grid-row grid-gap">
          <aside class="tablet:grid-col-3 margin-bottom-4 tablet:margin-bottom-0">
            <nav aria-label="Side navigation" class="sticky-nav">
              <ul class="usa-sidenav">
                {navItems.map((item) => (
                  <li class="usa-sidenav__item">
                    <a
                      href={item.href}
                      class={currentPage === item.id ? "usa-current" : ""}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
          <div class="tablet:grid-col-9">
            <slot />
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .sticky-nav {
    position: sticky;
    top: 2rem;
    align-self: start;
  }

  /* Council breadcrumb */
  .council-breadcrumb {
    background-color: var(--primary-color);
    padding: 0.75rem 0;
  }

  .council-breadcrumb .usa-breadcrumb__list {
    max-width: var(--max-width);
    margin-left: auto;
    margin-right: auto;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  @media (min-width: 640px) {
    .council-breadcrumb .usa-breadcrumb__list {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  .council-breadcrumb .usa-breadcrumb__link,
  .council-breadcrumb .usa-breadcrumb__current {
    color: white;
  }

  .council-breadcrumb .usa-breadcrumb__link:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .council-hero {
    background-color: var(--primary-color);
    background-image: url('/assets/img/backgrounds/waves_2.svg');
    background-repeat: repeat;
    /* Scale options: 
       - Use percentage: background-size: 50%; (smaller) or 200%; (larger)
       - Use pixels: background-size: 1000px 400px; (width height)
       - Use cover/contain: background-size: cover; (fills area) or contain; (fits area)
    */
    background-size: 30%;
    /* Blend mode options: overlay, multiply, screen, soft-light, or normal */
    background-blend-mode: multiply;
  }

  .council-hero__logo-container {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: white;
    padding: 1.5rem;
  }

  .council-hero__logo {
    max-height: 200px;
    width: auto;
    height: auto;
    display: block;
  }

  .council-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    color: white;
  }

  .council-hero__brow {
    color: white;
    font-size: 1rem; /* 16px */
    font-weight: 400;
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .council-hero__title {
    color: white;
    font-size: 2rem;
    font-weight: 400;
    margin-top: 1rem;
    margin-bottom: 1rem;

  }

  @media (min-width: 640px) {
    .council-hero__logo {
      max-height: 250px;
    }

    .council-hero__title {
      font-size: 2.5rem;
    }
  }

  /* Remove top margin from all h2s, then add back to subsequent ones */
  .tablet\:grid-col-9 h2 {
    margin-top: 0 !important;
  }
  
  /* Add margin back to h2s that follow other elements */
  .tablet\:grid-col-9 h2:not(:first-of-type),
  .tablet\:grid-col-9 > div h2:not(:first-of-type),
  .tablet\:grid-col-9 p + h2,
  .tablet\:grid-col-9 > div p + h2 {
    margin-top: 2rem !important;
  }

  /* Legacy logo classes for backward compatibility */
  .council-logo-large,
  .cioc-logo-about {
    max-height: 250px;
    width: auto;
    height: auto;
    display: block;
    margin-left: auto;
    margin-right: auto;
  }

</style>

