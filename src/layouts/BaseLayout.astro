---
import USWDSBanner from '../components/USWDSBanner.astro';
import USWDSHeader from '../components/USWDSHeader.astro';
import USWDSFooter from '../components/USWDSFooter.astro';
import USWDSIdentifier from '../components/USWDSIdentifier.astro';
import Meta from '../components/Meta.astro';
import '../styles/uswds-custom.scss';
import '../styles/variables.css';
import '../styles/global.scss';

interface Props {
  title?: string;
  description?: string;
  currentPage?: string;
  noIndex?: boolean;
}

const { title, description, currentPage, noIndex } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <slot name="head" />
    <meta name="generator" content={Astro.generator} />
    <Meta title={title} description={description} noIndex={noIndex} />
    <style>
      html.no-js .usa-nav__submenu { display: none; }
    </style>
    <script>
      document.documentElement.classList.remove('no-js');
      document.documentElement.classList.add('js');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,900;1,400;1,500;1,600;1,700;1,900&display=optional"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,900;1,400;1,500;1,600;1,700;1,900&display=swap"
      />
    </noscript>
    <script is:inline>
      (function() {
        function loadDeferred() {
          var dap = document.createElement('script');
          dap.defer = true;
          dap.id = '_fed_an_ua_tag';
          dap.src = 'https://dap.digitalgov.gov/Universal-Federated-Analytics-Min.js?agency=GSA&subagency=TTS';
          document.head.appendChild(dap);

          window.usasearch_config = { siteHandle: "councils.gov" };
          var usa = document.createElement('script');
          usa.async = true;
          usa.src = 'https://search.usa.gov/javascripts/remote.loader.js';
          usa.type = 'text/javascript';
          document.head.appendChild(usa);
        }
        if (document.readyState === 'complete') {
          loadDeferred();
        } else {
          window.addEventListener('load', loadDeferred);
        }
      })();
    </script>
  </head>
  <body>
    <a class="usa-skipnav" href="#main-content">
      Skip to main content
    </a>
    <USWDSBanner />
    <USWDSHeader currentPage={currentPage} />
    <slot />
    <USWDSFooter />
    <USWDSIdentifier />
    <script>
      (function() {
        'use strict';
        
        function initUSWDS() {
          import('@uswds/uswds').then((uswds) => {
            if (uswds.on && typeof uswds.on === 'function') {
              uswds.on(window);
            } else if (uswds.default && typeof uswds.default.on === 'function') {
              uswds.default.on(window);
            }
          }).catch(() => {
            console.warn('USWDS JavaScript could not be loaded');
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initUSWDS);
        } else {
          initUSWDS();
        }

        document.addEventListener('astro:after-swap', function() {
          setTimeout(initUSWDS, 0);
        });
        document.addEventListener('astro:page-load', function() {
          setTimeout(initUSWDS, 0);
        });
      })();
    </script>
  </body>
</html>
