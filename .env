# Search.gov configuration
# 1. Create an account: https://search.usa.gov/signup
# 2. Add a new site in the Admin Center
# 3. Get your affiliate (site handle) and access key from the Admin Center
# 4. Copy this file to .env and fill in your values
#
# Temporary: You can use another project's credentials until councils-gov is set up.
# Replace with your own when ready.

# Site handle from Search.gov Admin Center (e.g. councils-gov)
# Use restorethegulf temporarily until councils-gov is indexed
PUBLIC_SEARCH_AFFILIATE=councils-gov

# API access key from Search.gov Admin Center > API Access Key page
PUBLIC_SEARCH_ACCESS_KEY=GTOTlVh8bhpxAGWz6hoLxF3aGhM-VUd59RNL6VPWyh8=

